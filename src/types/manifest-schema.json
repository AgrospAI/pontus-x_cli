{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "accounts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "passwordEnvKey": {
            "type": "string"
          },
          "privateKeyPath": {
            "type": "string"
          }
        },
        "required": [
          "address",
          "passwordEnvKey",
          "privateKeyPath"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "accounts"
  ],
  "additionalProperties": false
}